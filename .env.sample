# =========================
# Core Application
# =========================
FA_ENV=local
LOG_LEVEL=INFO
ENABLE_DOCS=true
ENABLE_REDOC=false

# Optional overrides
# Leave these empty for normal local mode.
# `./run.sh local dev` and `./run.sh local prd` can override them at runtime.
CHAT_BACKEND_URL=
AUTH_BACKEND_URL=
ADMIN_API_TOKEN=
MAX_ACTIVE_GENERATIONS=3

# =========================
# OpenSearch
# =========================
OPENSEARCH_API_URL=
OPENSEARCH_API_USR=
OPENSEARCH_API_PWD=
VERIFY_SSL=true
OS_API_PATH=/neural_search_relevant

# =========================
# vLLM
# =========================
VLLM_URL=http://localhost:8000
RUNPOD_VLLM_HOST=
VLLM_MODEL=qwen3-30b-a3b-awq
VLLM_API_KEY=

# =========================
# Generation Limits
# =========================
MAX_TOKENS=-1
TEMPERATURE=0.4
NUM_CTX=16384
TOP_K=5
MAX_CONTEXT_CHARS=24000
MAX_OUTPUT_TOKENS=1024
MAX_INPUT_TOKENS=12000
MAX_USER_INPUT_TOKENS=2000

# =========================
# Cache
# =========================
REDIS_URL=redis://127.0.0.1:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400

# =========================
# TTS
# =========================
PIPER_MODELS_DIR=/app/models
