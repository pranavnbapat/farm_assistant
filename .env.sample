# =========================
# Core Application
# =========================
# Runtime environment: local | dev | prd (selects default backend URLs).
FA_ENV=local
# Logging verbosity: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
# Serve the Swagger UI at /docs when true.
ENABLE_DOCS=true
# Serve the ReDoc UI at /redoc when true.
ENABLE_REDOC=false

# Django auth/chat backend base URL (blank = auto-resolved from FA_ENV).
CHAT_BACKEND_URL=
# Override for the auth backend base URL (blank = same as CHAT_BACKEND_URL).
AUTH_BACKEND_URL=
# Shared token for privileged admin endpoints.
ADMIN_API_TOKEN=
# Max number of concurrent streaming generations allowed in this process.
MAX_ACTIVE_GENERATIONS=3

# =========================
# OpenSearch
# =========================
# Base URL of the retrieval (OpenSearch FastAPI) service.
OPENSEARCH_API_URL=
# Basic-auth username for the retrieval service.
OPENSEARCH_API_USR=
# Basic-auth password for the retrieval service.
OPENSEARCH_API_PWD=
# Verify TLS certificates on outbound HTTPS calls.
VERIFY_SSL=true
# Retrieval endpoint path for neural search.
OS_API_PATH=/neural_search_relevant
# Retrieval endpoint path for RAG chunk fetch.
OS_RAG_API_PATH=/llm_retrieve

# =========================
# vLLM
# =========================
# OpenAI-compatible vLLM base URL for chat generation.
VLLM_URL=http://localhost:8000
# RunPod host override for the vLLM endpoint (optional).
RUNPOD_VLLM_HOST=
# Model id served by vLLM for chat generation.
VLLM_MODEL=qwen3-30b-a3b-awq
# Bearer key for the vLLM endpoint (optional).
VLLM_API_KEY=
# RunPod host for the vision model endpoint (optional).
RUNPOD_VLLM_VISION_HOST=
# Vision model id for image analysis (optional).
VLLM_VISION_MODEL=
# Bearer key for the vision endpoint (optional).
VLLM_VISION_API_KEY=

# =========================
# Generation Limits
# =========================
# Max output tokens (-1 = model default / unlimited).
MAX_TOKENS=-1
# Sampling temperature for generation.
TEMPERATURE=0.4
# Context window size in tokens.
NUM_CTX=16384
# Top-k sampling cutoff.
TOP_K=5
# Number of candidate chunks to retrieve.
RETRIEVAL_CANDIDATE_K=10
# Minimum retrieval score required to keep a chunk.
RETRIEVAL_MIN_SCORE=1.0
# Hard-drop retrieval when quality is below this threshold.
RETRIEVAL_DROP_THRESHOLD=0.15
# Relevance gate mode: "overlap" (lexical word-overlap) or "semantic" (cosine; needs calibration).
RELEVANCE_MODE=overlap
# Semantic mode: cosine below which retrieved context is dropped.
SEMANTIC_DROP_THRESHOLD=0.88
# Semantic mode: cosine below which web fallback is considered.
SEMANTIC_WEB_THRESHOLD=0.90
# Max characters of context assembled into the prompt.
MAX_CONTEXT_CHARS=24000
# Max tokens generated per answer.
MAX_OUTPUT_TOKENS=1024
# Max prompt tokens sent to the model.
MAX_INPUT_TOKENS=12000
# Max tokens accepted from the user's question.
MAX_USER_INPUT_TOKENS=2000

# =========================
# Web-search fallback (default OFF)
# =========================
# Enable trusted-allowlist web search when internal OpenSearch retrieval is empty/weak.
WEB_FALLBACK_ENABLED=false
# Ordered provider fallback chain, tried left to right (a provider is skipped if its key is unset).
WEB_SEARCH_PROVIDERS=tavily,staan,brave,duckduckgo
# API key for Tavily web search (optional).
TAVILY_API_KEY=
# API key for STAAN / EU-sovereign search (optional; impl not yet wired).
STAAN_API_KEY=
# API key for Brave web search (optional).
BRAVE_API_KEY=
# Retrieval quality below which the web fallback triggers.
WEB_FALLBACK_QUALITY_THRESHOLD=0.35
# Max number of web results to fetch.
WEB_FALLBACK_MAX_RESULTS=4
# Max characters extracted per web page.
WEB_FALLBACK_MAX_CHARS=6000
# Per-page fetch timeout in seconds.
WEB_FETCH_TIMEOUT=6.0
# Allowlist of domains web results must come from.
WEB_TRUSTED_DOMAINS=fao.org,europa.eu,ec.europa.eu,efsa.europa.eu,eppo.int,oecd.org,inrae.fr,wur.nl,teagasc.ie,ahdb.org.uk

# =========================
# Automated Arena Evaluation
# =========================
# IMPORTANT auth-realm invariant: AUTOMATION_SERVICE_* logs in against CHAT_BACKEND_URL
# (Django) and the resulting JWT is presented to the Qwen3 / EuroLLM answer backends.
# CHAT_BACKEND_URL and those deployments must validate JWTs against the SAME Django
# environment, or fan-out calls return 401. (Mistral/TNO uses X-API-Key, not the JWT.)
#
# Master switch for the automated arena evaluation feature.
AUTOMATION_ENABLED=false
# Token guarding the HTTP trigger endpoint (the CLI runner ignores it).
AUTOMATION_TOKEN=
# Service-account email used for the single automation login.
AUTOMATION_SERVICE_EMAIL=
# Service-account password used for the single automation login.
AUTOMATION_SERVICE_PASSWORD=
# experiment_key tag stored on every automated comparison run.
AUTOMATION_EXPERIMENT_ID=automated_eval
# Agriculture:non-agriculture ratio of generated questions.
AUTOMATION_TOPIC_RATIO=3:1
# Distinct base questions per cycle (each localized into all requested languages).
AUTOMATION_BASE_QUESTION_COUNT=1
# Min chatbot answers required to keep a question (3 = require all three models).
AUTOMATION_MIN_ANSWERS=3
# Questions processed at a time (1 = strictly sequential: one question across all models, store, next).
AUTOMATION_MAX_CONCURRENCY=1
# Per-request timeout in seconds for chatbot and judge calls.
AUTOMATION_REQUEST_TIMEOUT=180
# Output token budget for one base question localized into all requested languages.
AUTOMATION_QUESTION_MAX_TOKENS=12000
# Qwen3 chatbot deployment base URL.
FARM_ASSISTANT_UM_QWEN3_URL=https://farm-assistant.nexavion.com
# Model id reported/recorded for the Qwen3 backend.
FARM_ASSISTANT_UM_QWEN3_MODEL_NAME=qwen3-30b-a3b-awq
# EuroLLM chatbot deployment base URL.
FARM_ASSISTANT_EUROLLM_URL=http://127.0.0.1:18005
# Model id reported/recorded for the EuroLLM backend.
FARM_ASSISTANT_EUROLLM_MODEL_NAME=utter-project/EuroLLM-9B-Instruct
# Mistral / TNO (tnods) chatbot base URL.
EUF_CHATBOT_API_URL=https://farm-assistant.tnods.nl
# X-API-Key for the TNO chatbot (required, or Mistral is excluded).
EUF_CHATBOT_API_KEY=
# Fixed arena uuid header sent to the TNO chatbot.
EUF_CHATBOT_ARENA_UUID=45b75f62-3fa3-4b18-8593-1411f110a98e
# Model id reported/recorded for the Mistral/TNO backend.
EUF_CHATBOT_MODEL_NAME=azure_ai/mistral-small-2503
# OpenAI API key for the LLM judge.
JUDGE_OPENAI_API_KEY=
# OpenAI-compatible base URL for the judge.
JUDGE_OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI model id used as a judge.
JUDGE_OPENAI_MODEL=gpt-5.4-mini
# Anthropic API key for the LLM judge.
JUDGE_ANTHROPIC_API_KEY=
# Anthropic model id used as a judge.
JUDGE_ANTHROPIC_MODEL=claude-haiku-4-5
# Judge OUTPUT cap only (input = question + 3 answers is separate/uncapped). Raise for reasoning models.
JUDGE_MAX_TOKENS=6000
# Sampling temperature for the judges (0 = deterministic).
JUDGE_TEMPERATURE=0

# --- Design 2: controlled (shared-context) comparison ---
# ON => one FA "preparer" runs retrieval+prompt ONCE, and Qwen+EuroLLM generate from that
# identical prompt via raw vLLM (model-only comparison). Mistral stays full-system (flagged).
# The PREPARER instance must run a farm_assistant build that has the prepare_only flag.
AUTOMATION_CONTROLLED_ENABLED=false
# FA instance that runs prepare_only (its config = the shared retrieval/prompt/web knobs).
# Blank -> FARM_ASSISTANT_UM_QWEN3_URL.
CONTROLLED_PREPARER_URL=
# Raw vLLM /v1 generation endpoints. Qwen blanks fall back to the main vLLM config above.
CONTROLLED_QWEN_VLLM_URL=
CONTROLLED_QWEN_MODEL=
CONTROLLED_QWEN_API_KEY=
CONTROLLED_EUROLLM_VLLM_URL=https://bqbozgg4zi5ju6-8000.proxy.runpod.net
CONTROLLED_EUROLLM_MODEL=current
CONTROLLED_EUROLLM_API_KEY=
# Identical top_p for both models (temperature/max_tokens come from the preparer's prompt).
CONTROLLED_TOP_P=0.9

# =========================
# TTS
# =========================
# Directory holding the Piper TTS voice models.
PIPER_MODELS_DIR=/app/models
