# =========================
# Core Application
# =========================
FA_ENV=local
LOG_LEVEL=INFO
ENABLE_DOCS=true
ENABLE_REDOC=false

# Optional overrides
# Leave these empty for normal local mode.
# `./run.sh local dev` and `./run.sh local prd` can override them at runtime.
CHAT_BACKEND_URL=
AUTH_BACKEND_URL=
ADMIN_API_TOKEN=
MAX_ACTIVE_GENERATIONS=3

# =========================
# OpenSearch
# =========================
OPENSEARCH_API_URL=
OPENSEARCH_API_USR=
OPENSEARCH_API_PWD=
VERIFY_SSL=true
OS_API_PATH=/neural_search_relevant
OS_RAG_API_PATH=/llm_retrieve

# =========================
# vLLM
# =========================
VLLM_URL=http://localhost:8000
RUNPOD_VLLM_HOST=
VLLM_MODEL=qwen3-30b-a3b-awq
VLLM_API_KEY=
RUNPOD_VLLM_VISION_HOST=
VLLM_VISION_MODEL=
VLLM_VISION_API_KEY=

# =========================
# Generation Limits
# =========================
MAX_TOKENS=-1
TEMPERATURE=0.4
NUM_CTX=16384
TOP_K=5
RETRIEVAL_CANDIDATE_K=10
RETRIEVAL_MIN_SCORE=1.0
RETRIEVAL_DROP_THRESHOLD=0.15
# Relevance gate: "overlap" (lexical word-overlap, default) or "semantic" (scout's
# content_embedding cosine via include_semantic_score). Semantic thresholds are on the
# raw cosine scale (~0..1) and MUST be calibrated against ClickHouse /llm_retrieve logs.
RELEVANCE_MODE=overlap
SEMANTIC_DROP_THRESHOLD=0.88
SEMANTIC_WEB_THRESHOLD=0.90
MAX_CONTEXT_CHARS=24000
MAX_OUTPUT_TOKENS=1024
MAX_INPUT_TOKENS=12000
MAX_USER_INPUT_TOKENS=2000

# =========================
# Web-search fallback (default OFF)
# =========================
# When true, the normal retrieval turn searches a trusted allowlist of agriculture
# /forestry web sources whenever internal OpenSearch retrieval is empty or weak, and
# feeds the extracted passages to the LLM as cited grounding. The backend searches; the
# model never browses.
WEB_FALLBACK_ENABLED=false
# Ordered provider fallback chain (tried left to right). A provider is skipped if its
# key is missing, and the chain advances on any error/quota/empty result.
#   tavily     - best quality, returns pre-cleaned content (needs TAVILY_API_KEY)
#   staan      - EU-sovereign index (EUSP/Qwant+Ecosia); needs STAAN_API_KEY. Endpoint
#                not yet wired (see web_search_service); auto-skipped until key + impl.
#   brave      - stable web search (needs BRAVE_API_KEY; auto-skipped if unset)
#   duckduckgo - free, keyless web search (needs `ddgs` + `trafilatura`)
# Any keyed provider whose key is unset is simply skipped, on to the next.
# FAO/EU institutional CONTENT is already reachable via WEB_TRUSTED_DOMAINS below
# (fao.org, europa.eu, ec.europa.eu, efsa.europa.eu) through the providers above.
WEB_SEARCH_PROVIDERS=tavily,staan,brave,duckduckgo
TAVILY_API_KEY=
STAAN_API_KEY=
BRAVE_API_KEY=
WEB_FALLBACK_QUALITY_THRESHOLD=0.35
WEB_FALLBACK_MAX_RESULTS=4
WEB_FALLBACK_MAX_CHARS=6000
WEB_FETCH_TIMEOUT=6.0
WEB_TRUSTED_DOMAINS=fao.org,europa.eu,ec.europa.eu,efsa.europa.eu,eppo.int,oecd.org,inrae.fr,wur.nl,teagasc.ie,ahdb.org.uk

# =========================
# TTS
# =========================
PIPER_MODELS_DIR=/app/models
